{
  "name": "logiclink-desk",
  "version": "0.1.1",
  "description": "CLI tooling for LOGIClink Bluetooth standing desks.",
  "bin": {
    "logiclink-desk": "npm/bin/logiclink-desk.js"
  },
  "files": [
    "npm/",
    "prebuilt/",
    "README.md"
  ],
  "scripts": {
    "build:release": "cargo build --release",
    "package:binary": "node npm/scripts/package-binary.js",
    "prepare:binary": "npm run build:release && npm run package:binary",
    "prepack": "node npm/scripts/verify-package.js"
  },
  "keywords": [
    "bluetooth",
    "desk",
    "standing-desk",
    "logiclink",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philstainer/logiclink-desk"
  },
  "engines": {
    "node": ">=20"
  }
}
